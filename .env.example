APP_URL=http://localhost:3000
AUTH_COOKIE_NAME=ottomob_session
AUTH_JWT_SECRET=replace_with_a_long_random_secret

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ottomob
MYSQL_USER=ottomob_user
MYSQL_PASSWORD=change_me

# AmazingSMM API - reserved for later stages
AMAZINGSMM_API_URL=https://amazingsmm.com/api/v2
AMAZINGSMM_API_KEY=your_api_key_here
SERVICE_SYNC_SECRET=replace_with_a_private_sync_secret

# Google OAuth - configure in Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://ottomob.com/api/auth/google/callback

# Payments - reserved for later stages
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CURRENCY=usd
